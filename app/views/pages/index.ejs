<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bonus em Matrículas de Cursos</title>
</head>
<body>

     <%
        var cssErro = {"nome":"","email":"","cnpj":""}  
        var msgErro = {"nome":"","email":"","cnpj":""}
    if(listaErros) { 
         
        listaErros.errors.forEach(function(itemErro){
             if (itemErro.path  == "nome"){ 
                cssErro.nome = "erro";
                msgErro.nome = itemErro.msg;
            }  
             if (itemErro.path  == "cpf"){ 
                cssErro.cpf = "erro";
                msgErro.cpf = itemErro.msg;            
             }  
             if (itemErro.path  == "compra"){
                cssErro.compra = "erro";
                msgErro.compra = itemErro.msg;                
             }  
         }); 
     }; %>


     <form method="post" action="/index">

        <label for="nome">Nome Completo:</label>
        <input type="text" id="nome" name="nome" value="<%= valores.nome %>" class="<%= erroValidacao.nome %>">
        <span><%= msgErro.nome %></span>
        <br>

        <label for="cpf">CPF:</label>
        <input type="text" id="cpf" name="cpf" value="<%= valores.cpf %>" class="<%= erroValidacao.cpf %>">
        <span><%= msgErro.cpf %></span>
        <br>

        <label for="compra">Valor da Compra:</label>
        <input type="text" id="compra" name="compra" value="<%= valores.compra %>" class="<%= erroValidacao.compra %>">
        <span><%= msgErro.compra %></span>

        <button type="submit">Enviar</button>
    </form>

      <% if(resultado){%>
        <h2>Resutados:</h2>
        <p>Nome: <%= resultado.nome %>  </p>
        <p>CPF: <%= resultado.cpf %> </p>
        <p>Valor da Compra: <%= resultado.compra%> </p>
    <% }else{%>
        <h2>Não temos retorno</h2>
    <% }%>

    
</body>
</html>